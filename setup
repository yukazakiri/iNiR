###############################################################################
# My Changes - View and restore preserved user modifications
###############################################################################
run_my_changes() {
    echo ""
    tui_title "Your Preserved Modifications"
    echo ""

    # Check if any preserved modifications exist
    if [[ ! -d "$USER_MODS_DIR" ]] || [[ -z "$(ls -A "$USER_MODS_DIR" 2>/dev/null)" ]]; then
        tui_info "No preserved modifications found."
        echo ""
        tui_dim "When you update and have local changes, they are saved here."
        tui_dim "You can then restore them after the update completes."
        echo ""
        read -rp "Press Enter to continue..."
        return 0
    fi

    # List available preserved modifications
    local mods_list=($(ls -1t "$USER_MODS_DIR" 2>/dev/null))

    if [[ ${#mods_list[@]} -eq 0 ]]; then
        tui_info "No preserved modifications found."
        read -rp "Press Enter to continue..."
        return 0
    fi

    # Build options with details
    local options=()
    for mod_dir in "${mods_list[@]}"; do
        local meta="${USER_MODS_DIR}/${mod_dir}/metadata.json"
        if [[ -f "$meta" ]]; then
            local mod_count=$(grep -o '"modified_count": [0-9]*' "$meta" 2>/dev/null | grep -o '[0-9]*' || echo 0)
            local add_count=$(grep -o '"additions_count": [0-9]*' "$meta" 2>/dev/null | grep -o '[0-9]*' || echo 0)
            local date_formatted=$(echo "$mod_dir" | sed 's/\([0-9]\{4\}\)\([0-9]\{2\}\)\([0-9]\{2\}\)-\([0-9]\{2\}\)\([0-9]\{2\}\)\([0-9]\{2\}\)/\1-\2-\3 \4:\5/')
            options+=("$date_formatted (${mod_count} modified, ${add_count} added)")
        else
            options+=("$mod_dir")
        fi
    done
    options+=("Back")

    local choice
    choice=$(tui_choose "Select a backup to view/restore:" "${options[@]}")

    [[ "$choice" == "Back" ]] && return 0

    # Find which backup was selected
    local selected_idx=0
    for i in "${!options[@]}"; do
        if [[ "${options[$i]}" == "$choice" ]]; then
            selected_idx=$i
            break
        fi
    done

    local selected_dir="${mods_list[$selected_idx]}"
    local selected_path="${USER_MODS_DIR}/${selected_dir}"

    # Show contents of selected backup
    echo ""
    tui_subtitle "Contents of $selected_dir"
    echo ""

    # List modified files
    if [[ -d "$selected_path" ]]; then
        local files_found=false

        # Show modified files (excluding _additions and metadata)
        while IFS= read -r file; do
            [[ "$file" == *"metadata.json" ]] && continue
            [[ "$file" == *"_additions"* ]] && continue
            files_found=true
            local rel_path="${file#$selected_path/}"
            echo "    [modified] $rel_path"
        done < <(find "$selected_path" -type f 2>/dev/null)

        # Show additions
        if [[ -d "$selected_path/_additions" ]]; then
            while IFS= read -r file; do
                files_found=true
                local rel_path="${file#$selected_path/_additions/}"
                echo "    [added]    $rel_path"
            done < <(find "$selected_path/_additions" -type f 2>/dev/null)
        fi

        if ! $files_found; then
            tui_dim "    (no files found)"
        fi
    fi

    echo ""

    # Action menu
    local action
    action=$(tui_choose "What would you like to do?" \
        "Restore All" \
        "Restore Single File" \
        "Open in File Manager" \
        "Delete This Backup" \
        "Back")

    case "$action" in
        "Restore All")
            echo ""
            tui_warn "This will copy all preserved files back to your installation."
            tui_info "Existing files will be overwritten."
            if tui_confirm "Continue?" "no"; then
                restore_all_user_mods "$selected_path"
            fi
            ;;
        "Restore Single File")
            restore_single_user_mod "$selected_path"
            ;;
        "Open in File Manager")
            if command -v xdg-open &>/dev/null; then
                xdg-open "$selected_path" &>/dev/null &
                tui_success "Opened in file manager"
            else
                tui_info "Path: $selected_path"
            fi
            ;;
        "Delete This Backup")
            if tui_confirm "Delete this backup permanently?" "no"; then
                rm -rf "$selected_path"
                tui_success "Backup deleted"
            fi
            ;;
        *)
            return 0
            ;;
    esac

    echo ""
    read -rp "Press Enter to continue..."
}

# Helper: Restore all files from a user-mods backup
restore_all_user_mods() {
    local backup_path="$1"
    local target
    target="$(get_runtime_shell_dir)"
    local restored=0

    # Restore modified files
    while IFS= read -r file; do
        [[ "$file" == *"metadata.json" ]] && continue
        [[ "$file" == *"_additions"* ]] && continue

        local rel_path="${file#$backup_path/}"
        local dest="${target}/${rel_path}"

        mkdir -p "$(dirname "$dest")"
        cp "$file" "$dest"
        ((restored++))
        tui_dim "  Restored: $rel_path"
    done < <(find "$backup_path" -type f 2>/dev/null)

    # Restore additions
    if [[ -d "$backup_path/_additions" ]]; then
        while IFS= read -r file; do
            local rel_path="${file#$backup_path/_additions/}"
            local dest="${target}/${rel_path}"

            mkdir -p "$(dirname "$dest")"
            cp "$file" "$dest"
            ((restored++))
            tui_dim "  Restored: $rel_path"
        done < <(find "$backup_path/_additions" -type f 2>/dev/null)
    fi

    echo ""
    tui_success "Restored $restored file(s)"
    tui_info "Restart the shell to apply changes: inir restart"
}

# Helper: Restore a single file from user-mods backup
restore_single_user_mod() {
    local backup_path="$1"
    local target
    target="$(get_runtime_shell_dir)"

    # Build list of files
    local files=()
    while IFS= read -r file; do
        [[ "$file" == *"metadata.json" ]] && continue
        [[ "$file" == *"_additions"* ]] && continue
        local rel_path="${file#$backup_path/}"
        files+=("$rel_path")
    done < <(find "$backup_path" -type f 2>/dev/null)

    # Add files from _additions
    if [[ -d "$backup_path/_additions" ]]; then
        while IFS= read -r file; do
            local rel_path="${file#$backup_path/_additions/}"
            files+=("[added] $rel_path")
        done < <(find "$backup_path/_additions" -type f 2>/dev/null)
    fi

    if [[ ${#files[@]} -eq 0 ]]; then
        tui_warn "No files to restore"
        return 1
    fi

    files+=("Cancel")

    local choice
    choice=$(tui_choose "Select file to restore:" "${files[@]}")

    [[ "$choice" == "Cancel" ]] && return 0

    # Handle [added] prefix
    local src_file dest_file
    if [[ "$choice" == "[added] "* ]]; then
        local rel_path="${choice#\[added\] }"
        src_file="$backup_path/_additions/$rel_path"
        dest_file="$target/$rel_path"
    else
        src_file="$backup_path/$choice"
        dest_file="$target/$choice"
    fi

    mkdir -p "$(dirname "$dest_file")"
    cp "$src_file" "$dest_file"
    tui_success "Restored: $choice"
    tui_info "Restart the shell to apply changes: inir restart"
}

###############################################################################
# Update
###############################################################################
run_update() {
    echo ""
    tui_title "Checking for updates..."
    echo ""

    local installed_mode=$(get_installed_install_mode)
    local installed_strategy=$(get_installed_update_strategy)
    local package_name=$(get_installed_package_name)
    local update_hint=$(get_installed_package_update_hint)

    if [[ "$installed_strategy" == "package-manager" ]]; then
        tui_warn "This iNiR installation is package-managed"
        tui_status_line "Install Mode:" "$installed_mode" ""
        [[ -n "$package_name" ]] && tui_status_line "Package:" "$package_name" ""
        if [[ -n "$update_hint" ]]; then
            tui_info "Update the shell payload with: $update_hint"
        else
            tui_info "Update the shell payload with your package manager."
        fi

        local pending=$(count_pending_migrations 2>/dev/null || echo "0")
        if [[ "$pending" -gt 0 ]]; then
            echo ""
            run_migrations_auto
            pending=$(count_pending_migrations 2>/dev/null || echo "0")
            if [[ "$pending" -gt 0 ]]; then
                tui_warn "$pending optional migration(s) available"
                if $ask && tui_confirm "Review and apply now?"; then
                    run_migrations_interactive
                fi
            fi
        fi

        echo ""
        tui_success "Package-managed installation left unchanged"
        return 0
    fi

    # After a git pull, the setup script re-execs itself so that updated library
    # code (doctor, migrations, etc.) is loaded fresh. _II_POST_PULL signals that
    # we already pulled and should skip straight to the sync phase.
    if [[ "${_II_POST_PULL:-}" == "1" ]]; then
        unset _II_POST_PULL
        tui_success "Libraries reloaded after pull"
    else
        local update_rc=0
        check_remote_updates || update_rc=$?

        if [[ "$update_rc" -eq 0 ]]; then
            # Updates available
            show_pending_commits

            if $ask; then
                if ! tui_confirm "Pull and apply these updates?"; then
                    echo "Cancelled."
                    return 0
                fi
            fi

            # Create snapshot BEFORE pulling
            tui_info "Creating snapshot..."
            local remote_commit=$(get_remote_commit)
            local snapshot_id=$(create_snapshot "update" "Before update to ${remote_commit}" "$remote_commit")
            tui_success "Snapshot: $snapshot_id"

            # Pull changes
            tui_info "Pulling changes..."
            if ! git -C "$REPO_ROOT" pull --ff-only origin 2>/dev/null; then
                tui_error "Git pull failed. You may have local changes."
                tui_info "Try: git stash && ./setup update"
                return 1
            fi
            tui_success "Changes pulled"

            # Re-exec to pick up updated library code from the pull.
            # Without this, functions sourced at startup (doctor, migrations, etc.)
            # would still be the OLD versions in memory.
            local reexec_args=("update")
            $ask || reexec_args+=("-y")
            $quiet && reexec_args+=("-q")
            export _II_POST_PULL=1
            exec "$REPO_ROOT/setup" "${reexec_args[@]}"
        elif [[ "$update_rc" -eq 2 ]]; then
            # Could not check remote (offline or not a git repo)
            tui_warn "Could not check for remote updates (offline or not a git repo)"
            tui_info "Checking local repo vs installed version..."
        fi
        # Fall through: rc=1 (no updates) or rc=2 (error) — check local repo vs installed

        # Check if local repo is ahead of installed
        local installed_ver=$(get_installed_version)
        local installed_commit=$(get_installed_commit)
        local repo_ver=$(get_repo_version)
        local repo_commit=$(get_repo_commit)

        if [[ "$installed_ver" == "0.0.0" ]] && [[ -f "${FIRSTRUN_FILE}" ]]; then
            tui_info "Detected existing installation without version tracking"
        elif [[ "$installed_commit" == "$repo_commit" ]]; then
            tui_success "Already up to date ($installed_ver)"

            local pending=$(count_pending_migrations)
            if [[ "$pending" -gt 0 ]]; then
                echo ""
                tui_warn "$pending pending migration(s) available"
                if $ask && tui_confirm "Apply migrations now?"; then
                    run_migrations_interactive
                fi
            fi
            return 0
        else
            # Local repo ahead of installed - create snapshot
            tui_info "Creating snapshot..."
            local snapshot_id=$(create_snapshot "update" "Before sync to ${repo_commit}" "$repo_commit")
            tui_success "Snapshot: $snapshot_id"
        fi
    fi

    # Sync files
    local repo_ver=$(get_repo_version)
    local repo_commit=$(get_repo_commit)

    echo ""
    tui_info "Syncing iNiR..."

    II_SOURCE="${REPO_ROOT}"
    II_TARGET="${XDG_CONFIG_HOME}/quickshell/inir"
    local legacy_runtime_dir="${XDG_CONFIG_HOME}/quickshell/ii"

    for dir in "$XDG_BIN_HOME" "$XDG_CACHE_HOME" "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_STATE_HOME" "$II_TARGET"; do
        [[ -n "$dir" ]] && mkdir -p "$dir"
    done

    # Check if source and target are the same (dev setup)
    local src_real=$(realpath "$II_SOURCE" 2>/dev/null || echo "$II_SOURCE")
    local tgt_real=$(realpath "$II_TARGET" 2>/dev/null || echo "$II_TARGET")

    if [[ "$src_real" != "$tgt_real" ]]; then
        local runtime_compare_dir="$II_TARGET"
        local runtime_manifest=""
        local legacy_transition=false

        if [[ ! -f "${II_TARGET}/shell.qml" ]] && [[ -f "${legacy_runtime_dir}/shell.qml" ]]; then
            runtime_compare_dir="$legacy_runtime_dir"
            legacy_transition=true
            tui_info "Detected legacy quickshell/ii runtime"
        fi

        PRESERVED_MODS_DIR=""
        runtime_manifest=$(find_runtime_manifest_file "$runtime_compare_dir" 2>/dev/null || true)
        if [[ -n "$runtime_manifest" ]] && manifest_has_checksums "$runtime_manifest"; then
            echo ""
            tui_info "Checking for local modifications..."

            local modified_files_str
            local added_files_str
            modified_files_str=$(detect_user_modifications "$runtime_compare_dir" "$runtime_manifest")
            added_files_str=$(detect_user_additions "$runtime_compare_dir" "$runtime_manifest")

            local mod_count=0
            local add_count=0
            [[ -n "$modified_files_str" ]] && mod_count=$(echo "$modified_files_str" | grep -c . || echo 0)
            [[ -n "$added_files_str" ]] && add_count=$(echo "$added_files_str" | grep -c . || echo 0)
            local total_mods=$((mod_count + add_count))

            if [[ $total_mods -gt 0 ]]; then
                if ! handle_user_modifications "$modified_files_str" "$added_files_str" "$runtime_compare_dir"; then
                    return 1  # User cancelled
                fi
            else
                tui_success "No local modifications detected"
            fi
        elif [[ "$legacy_transition" == "true" ]]; then
            echo ""
            tui_info "Preserving legacy quickshell/ii runtime..."
            PRESERVED_MODS_DIR=$(preserve_runtime_tree "$runtime_compare_dir" "legacy-runtime")
            tui_success "Legacy runtime preserved"
        elif [[ -f "${runtime_compare_dir}/shell.qml" ]]; then
            # No checksum manifest (v1 or missing) — compare installed files
            # directly against repo to catch user modifications before first v2 update
            echo ""
            tui_info "No checksum manifest — comparing installed files against repo..."

            local modified_files_str
            modified_files_str=$(detect_user_modifications_by_source_comparison "$runtime_compare_dir" "$REPO_ROOT")

            local mod_count=0
            [[ -n "$modified_files_str" ]] && mod_count=$(echo "$modified_files_str" | grep -c . || echo 0)

            if [[ $mod_count -gt 0 ]]; then
                if ! handle_user_modifications "$modified_files_str" "" "$runtime_compare_dir"; then
                    return 1  # User cancelled
                fi
            else
                tui_success "No local modifications detected"
            fi
        fi

        echo ""
        tui_info "Syncing files..."

        # Sync root QML files
        for qml in "${II_SOURCE}"/*.qml; do
            [[ -f "$qml" ]] && cp -f "$qml" "${II_TARGET}/$(basename "$qml")"
        done

        local runtime_root_manifest="${II_SOURCE}/sdata/runtime-root-files.txt"
        local runtime_dirs_manifest="${II_SOURCE}/sdata/runtime-payload-dirs.txt"

        if [[ -f "$runtime_root_manifest" ]]; then
            while IFS= read -r runtime_file; do
                [[ -n "$runtime_file" ]] || continue
                [[ -f "${II_SOURCE}/${runtime_file}" ]] && cp -f "${II_SOURCE}/${runtime_file}" "${II_TARGET}/${runtime_file}"
            done < "$runtime_root_manifest"
        fi

        if [[ -f "$runtime_dirs_manifest" ]]; then
            while IFS= read -r dir; do
                [[ -n "$dir" ]] || continue
                [[ -d "${II_SOURCE}/${dir}" ]] && mkdir -p "${II_TARGET}/${dir}" && rsync -a --delete --exclude='AGENTS.md' "${II_SOURCE}/${dir}/" "${II_TARGET}/${dir}/"
            done < "$runtime_dirs_manifest"
        fi

        # Cleanup deprecated files
        [[ -f "${II_TARGET}/requirements.txt" ]] && rm -f "${II_TARGET}/requirements.txt"

        # Show preservation reminder after sync
        if [[ -n "$PRESERVED_MODS_DIR" ]]; then
            echo ""
            tui_info "Reminder: Your modifications were saved to:"
            tui_dim "    $PRESERVED_MODS_DIR"
        fi
    fi

    # Generate manifest
    generate_manifest "$II_SOURCE" "${II_TARGET}/.inir-manifest"

    # Remove orphan files left from previous versions
    cleanup_orphans "$II_TARGET" "${II_TARGET}/.inir-manifest"

    # Fix permissions
    find "$II_TARGET/scripts" \( -name "*.sh" -o -name "*.fish" -o -name "*.py" \) -exec chmod +x {} \; 2>/dev/null || true
    [[ -f "${II_TARGET}/setup" ]] && chmod +x "${II_TARGET}/setup"

    local launcher_target="${XDG_BIN_HOME}/inir"
    if [[ -f "${REPO_ROOT}/scripts/inir" ]]; then
        mkdir -p "$XDG_BIN_HOME"
        cp -f "${REPO_ROOT}/scripts/inir" "$launcher_target"
        chmod +x "$launcher_target"
        ensure_launcher_path_in_shells "$XDG_BIN_HOME"
        if ! command -v inir &>/dev/null && [[ ":$PATH:" != *":${XDG_BIN_HOME}:"* ]]; then
            tui_warn "Launcher installed to ${launcher_target}, but ${XDG_BIN_HOME} is not in PATH for this shell"
        fi
    fi

    if [[ -f "${REPO_ROOT}/assets/icons/desktop-symbolic.svg" ]]; then
        local icon_target_dir="${XDG_DATA_HOME}/icons/hicolor/scalable/apps"
        mkdir -p "$icon_target_dir"
        cp -f "${REPO_ROOT}/assets/icons/desktop-symbolic.svg" "${icon_target_dir}/inir.svg"
    fi

    if [[ -f "${REPO_ROOT}/assets/applications/inir.desktop" ]]; then
        local applications_dir="${XDG_DATA_HOME}/applications"
        local desktop_tmp="${XDG_CACHE_HOME}/inir.desktop.$$"
        mkdir -p "$applications_dir"
        sed "s|^Exec=.*|Exec=${launcher_target//&/\\&} settings|" "${REPO_ROOT}/assets/applications/inir.desktop" > "$desktop_tmp"
        cp -f "$desktop_tmp" "${applications_dir}/inir.desktop"
        rm -f "$desktop_tmp"
    fi

    # Update version
    set_installed_version "$repo_ver" "$repo_commit" "update"

    if [[ -d "$II_TARGET" ]]; then
        write_version_info_json "${II_TARGET}/version.json" "$repo_ver" "$repo_commit" "setup-update"
    fi

    tui_success "Files synced"

    # Refresh ii-pixel SDDM theme on update (keeps shipped theme in sync with fixes)
    # Intelligent behavior:
    # - interactive mode: installer decides (prompt if another SDDM theme is active)
    # - non-interactive mode: never force-switch Current theme
    if command -v sddm >/dev/null 2>&1; then
        local sddm_script="${II_TARGET}/scripts/sddm/install-pixel-sddm.sh"
        if [[ -f "$sddm_script" ]]; then
            echo ""
            tui_info "Refreshing ii-pixel SDDM theme..."
            local _sddm_auto_apply="ask"
            if [[ "$ask" != "true" ]]; then
                _sddm_auto_apply="no"
            fi
            INIR_SDDM_AUTO_APPLY="${_sddm_auto_apply}" bash "$sddm_script" || tui_warn "SDDM refresh had issues (non-fatal)"
        fi
    fi

    # Update Vesktop themes (themes live outside quickshell/ii tree)
    if [[ -d "${REPO_ROOT}/dots/.config/vesktop/themes" ]]; then
        echo ""
        tui_info "Updating Vesktop themes..."

        mkdir -p "${XDG_CONFIG_HOME}/vesktop/themes"
        mkdir -p "${XDG_CONFIG_HOME}/Vesktop/themes"

        OLD_VESKTOP_THEMES=(
            "midnight-ii.theme.css"
            "dms-midnight.theme.css"
            "system24-ii.theme.css"
            "system24-palette.css"
            "ii-palette.css"
            "ii-system24.theme.css"
        )
        for old_theme in "${OLD_VESKTOP_THEMES[@]}"; do
            [[ -f "${XDG_CONFIG_HOME}/vesktop/themes/${old_theme}" ]] && rm -f "${XDG_CONFIG_HOME}/vesktop/themes/${old_theme}"
            [[ -f "${XDG_CONFIG_HOME}/Vesktop/themes/${old_theme}" ]] && rm -f "${XDG_CONFIG_HOME}/Vesktop/themes/${old_theme}"
        done

        install_dir "${REPO_ROOT}/dots/.config/vesktop/themes" "${XDG_CONFIG_HOME}/vesktop/themes"
        install_dir "${REPO_ROOT}/dots/.config/vesktop/themes" "${XDG_CONFIG_HOME}/Vesktop/themes"

        tui_success "Vesktop themes updated"
    fi

    # Migrations
    local pending=$(count_pending_migrations)
    if [[ "$pending" -gt 0 ]]; then
        echo ""
        # Always apply REQUIRED migrations automatically, then offer optional migrations.
        run_migrations_auto
        pending=$(count_pending_migrations)
        if [[ "$pending" -gt 0 ]]; then
            tui_warn "$pending optional migration(s) available"
            if $ask && tui_confirm "Review and apply?"; then
                run_migrations_interactive
            fi
        fi
    fi

    local niri_config="${XDG_CONFIG_HOME}/niri/config.kdl"
    local niri_startup_cfg="${XDG_CONFIG_HOME}/niri/config.d/50-startup.kdl"
    local niri_binds_cfg="${XDG_CONFIG_HOME}/niri/config.d/70-binds.kdl"
    if [[ -f "$niri_config" && -x "${XDG_BIN_HOME}/inir" ]]; then
        local launcher_target_escaped="${XDG_BIN_HOME}/inir"
        launcher_target_escaped="${launcher_target_escaped//&/\\&}"
        if [[ -f "$niri_startup_cfg" ]]; then
            sed -i \
                -e 's|spawn-at-startup "inir" "start"|spawn-at-startup "'"${launcher_target_escaped}"'" "start"|' \
                "$niri_startup_cfg"
        else
            sed -i \
                -e 's|spawn-at-startup "inir" "start"|spawn-at-startup "'"${launcher_target_escaped}"'" "start"|' \
                "$niri_config"
        fi

        if [[ -f "$niri_binds_cfg" ]]; then
            sed -i \
                -e 's|spawn "bash" "-lc" "exec \"\$(inir path)/scripts/launch-terminal.sh\""|spawn "'"${launcher_target_escaped}"'" "terminal"|' \
                -e 's|spawn "bash" "-lc" "exec \"\$(inir path)/scripts/close-window.sh\""|spawn "'"${launcher_target_escaped}"'" "close-window"|' \
                -e 's|spawn "inir" "|spawn "'"${launcher_target_escaped}"'" "|g' \
                "$niri_binds_cfg"
        else
            sed -i \
                -e 's|spawn "bash" "-lc" "exec \"\$(inir path)/scripts/launch-terminal.sh\""|spawn "'"${launcher_target_escaped}"'" "terminal"|' \
                -e 's|spawn "bash" "-lc" "exec \"\$(inir path)/scripts/close-window.sh\""|spawn "'"${launcher_target_escaped}"'" "close-window"|' \
                -e 's|spawn "inir" "|spawn "'"${launcher_target_escaped}"'" "|g' \
                "$niri_config"
        fi
    fi

    # DISABLED: webapps — requires quickshell-webengine rebuild, re-enable when ready
    # # Install default WebApp plugins for existing users
    # if [[ -d "${REPO_ROOT}/defaults/plugins" ]]; then
    #     local plugins_dir="${XDG_CONFIG_HOME}/illogical-impulse/plugins"
    #     mkdir -p "$plugins_dir"
    #     local new_plugins=0
    #     for plugin_src in "${REPO_ROOT}/defaults/plugins"/*/; do
    #         local pname=$(basename "$plugin_src")
    #         local pdest="${plugins_dir}/${pname}"
    #         if [[ ! -d "$pdest" ]]; then
    #             cp -r "$plugin_src" "$pdest"
    #             ((new_plugins++))
    #         else
    #             # Update userscripts only (don't overwrite user manifest/icon)
    #             if [[ -d "${plugin_src}scripts" ]]; then
    #                 mkdir -p "${pdest}/scripts"
    #                 cp -r "${plugin_src}scripts/"* "${pdest}/scripts/" 2>/dev/null || true
    #             fi
    #         fi
    #     done
    #     [[ $new_plugins -gt 0 ]] && tui_success "Installed $new_plugins default WebApp plugin(s)"
    # fi

    # Restart shell (only if we have access to the session)
    echo ""
    if [[ -n "$NIRI_SOCKET" ]] || [[ -n "$WAYLAND_DISPLAY" ]]; then
        tui_info "Restarting shell..."
        if [[ -x "${II_TARGET}/scripts/inir" ]]; then
            nohup bash "${II_TARGET}/scripts/inir" restart -c "${II_TARGET}" >/dev/null 2>&1 &
            disown
        else
            qs -p "${II_TARGET}" kill 2>/dev/null || true
            sleep 1
            nohup qs -p "${II_TARGET}" >/dev/null 2>&1 &
            disown
        fi
        tui_success "Shell restarted"
    else
        tui_warn "Not in graphical session - shell restart skipped"
        tui_info "The shell will use new files on next restart"
        tui_info "Or run: inir restart"
    fi

    # Post-update: check for missing dependencies and offer to install them
    echo ""
    tui_title "Dependency check"
    echo ""
    check_dependencies
    if [[ ${#doctor_missing_deps[@]} -gt 0 ]]; then
        tui_warn "Missing packages detected: ${doctor_missing_deps[*]}"
        if $ask; then
            # Interactive mode: offer to install
            if tui_confirm "Install missing packages now?"; then
                detect_distro
                SKIP_SYSUPDATE=true
                ONLY_MISSING_DEPS="${doctor_missing_deps[*]}"
                source ./sdata/subcmd-install/1.deps-router.sh
                tui_success "Dependencies installed"
            else
                tui_info "Skipped dependency installation"
            fi
        elif can_elevate; then
            # Non-interactive mode but can elevate (pkexec available) — install via graphical auth
            tui_info "Installing missing packages via graphical authentication..."
            detect_distro
            SKIP_SYSUPDATE=true
            ONLY_MISSING_DEPS="${doctor_missing_deps[*]}"
            USE_ELEVATE=true  # Signal deps-router to use elevate() instead of sudo
            source ./sdata/subcmd-install/1.deps-router.sh
            tui_success "Dependencies installed"
        else
            # No way to elevate — just inform
            tui_info "Run './setup doctor' to install missing packages"
        fi
    else
        tui_success "All required commands available"
    fi

    # DISABLED: webapps — requires quickshell-webengine rebuild, re-enable when ready
    # # WebApp plugins: check if quickshell has WebEngine support
    # if [[ -d "${REPO_ROOT}/defaults/plugins" ]]; then
    #     echo ""
    #     tui_title "WebApp Plugins"
    #     echo ""
    #
    #     local has_webengine=false
    #     if pacman -Q qt6-webengine &>/dev/null 2>&1; then
    #         has_webengine=true
    #     elif dpkg -s qt6-webengine-dev &>/dev/null 2>&1; then
    #         has_webengine=true
    #     elif rpm -q qt6-qtwebengine-devel &>/dev/null 2>&1; then
    #         has_webengine=true
    #     fi
    #
    #     # Check if quickshell was compiled with our WebEngine patch
    #     local qs_has_patch=false
    #     if strings "$(which qs 2>/dev/null || echo /usr/bin/quickshell)" 2>/dev/null | grep -q "EnableQtWebEngineQuick" 2>/dev/null; then
    #         qs_has_patch=true
    #     fi
    #
    #     if $qs_has_patch; then
    #         tui_success "Quickshell has WebEngine support"
    #         tui_info "Enable Web Apps in Settings → Interface → Sidebars"
    #     elif $has_webengine; then
    #         tui_info "qt6-webengine is installed but quickshell needs to be recompiled"
    #         tui_info "Web Apps (Discord, YouTube Music, etc.) require a patched quickshell"
    #         if $ask; then
    #             if tui_confirm "Build and install quickshell with WebEngine support?"; then
    #                 echo ""
    #                 _build_install_qs_webengine
    #             fi
    #         else
    #             tui_info "Run: cd ${REPO_ROOT}/scripts/quickshell-webengine && makepkg -si"
    #         fi
    #     else
    #         tui_info "WebApp plugins available (Discord, YouTube Music with adblock)"
    #         tui_info "Requires: qt6-webengine + patched quickshell"
    #         if $ask; then
    #             if tui_confirm "Install qt6-webengine and build patched quickshell?"; then
    #                 echo ""
    #                 if command -v pacman >/dev/null 2>&1; then
    #                     tui_info "Installing qt6-webengine..."
    #                     pkg_sudo pacman -S --needed --noconfirm qt6-webengine || true
    #                 fi
    #                 _build_install_qs_webengine
    #             fi
    #         else
    #             tui_info "To enable: pacman -S qt6-webengine"
    #             tui_info "Then: cd ${REPO_ROOT}/scripts/quickshell-webengine && makepkg -si"
    #         fi
    #     fi
    # fi

    # Update Python venv packages
    echo ""
    tui_title "Python packages"
    echo ""
    local venv_dir="${XDG_STATE_HOME}/quickshell/.venv"
    local req_file="${REPO_ROOT}/sdata/uv/requirements.txt"

    if [[ -f "$req_file" ]] && command -v uv &>/dev/null; then
        if [[ ! -d "$venv_dir/bin" ]]; then
            tui_info "Creating Python venv..."
            uv venv --prompt ii-venv "$venv_dir" -p 3.12 2>/dev/null || uv venv --prompt ii-venv "$venv_dir" 2>/dev/null
        fi

        if [[ -d "$venv_dir/bin" ]]; then
            tui_info "Updating Python packages..."
            source "$venv_dir/bin/activate"
            uv pip install -q -r "$req_file" 2>/dev/null
            deactivate
            tui_success "Python packages updated"
        fi
    else
        tui_success "Python packages (skipped - uv not available)"
    fi

    echo ""
    tui_subtitle "Tip: Run './setup rollback' if something breaks"
}

###############################################################################
# Doctor
###############################################################################
run_doctor() {
    echo ""
    tui_title "iNiR Doctor"
    echo ""
    run_doctor_with_fixes
}

###############################################################################
# Parse args
###############################################################################
COMMAND=""
SUBCMD_ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        install|update|migrate|doctor|rollback|my-changes|uninstall|status)
            COMMAND="$1"; shift
            SUBCMD_ARGS=("$@")
            break
            ;;
        -y|--yes) ask=false; shift ;;
        -q|--quiet) quiet=true; shift ;;
        --set-default-shell) export INIR_SET_DEFAULT_SHELL=true; shift ;;
        -h|--help) show_help; exit 0 ;;
        *) echo "Unknown: $1"; show_help; exit 1 ;;
    esac
done

# Check prerequisites for install command (after parsing flags)
if [[ "$COMMAND" == "install" ]]; then
  # Source install-specific option parser if there are subcommand args
  if [[ ${#SUBCMD_ARGS[@]} -gt 0 ]]; then
    source ./sdata/subcmd-install/options.sh "${SUBCMD_ARGS[@]}"
  fi
  _check_privilege_prereqs "install"
fi

###############################################################################
# Run
###############################################################################
case "$COMMAND" in
    install) run_install ;;
    update) run_update ;;
    migrate) run_migrate ;;
    doctor) run_doctor ;;
    rollback) run_rollback ;;
    my-changes) run_my_changes ;;
    uninstall) run_uninstall ;;
    status) show_status ;;
    "") tui_menu ;;
esac
