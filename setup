# Check privilege escalation availability
_check_privilege_prereqs() {
  # Load the package installers to get access to privilege detection
  source ./sdata/lib/package-installers.sh 2>/dev/null
  
  local can_escalate=false
  local method=""
  
  # Check each method
  if command -v sudo &>/dev/null && sudo -n true 2>/dev/null; then
    can_escalate=true
    method="sudo"
  elif command -v pkexec &>/dev/null && ( [[ -n "${DBUS_SESSION_BUS_ADDRESS}" ]] || [[ -n "${DISPLAY}" ]] || [[ -n "${WAYLAND_DISPLAY}" ]] ); then
    can_escalate=true
    method="pkexec"
  elif command -v su &>/dev/null && [[ -z "${DISPLAY}" ]] && [[ -z "${WAYLAND_DISPLAY}" ]]; then
    can_escalate=true
    method="su"
  fi
  
  if ! $can_escalate; then
    echo ""
    tui_warn "No privilege escalation method detected!"
    echo ""
    echo "This may cause installation to fail if sudo credentials are not cached."
    echo ""
    echo "Detected environment:"
    [[ -n "${DISPLAY}" ]] && echo "  - DISPLAY: ${DISPLAY}" || echo "  - DISPLAY: (not set)"
    [[ -n "${WAYLAND_DISPLAY}" ]] && echo "  - WAYLAND: ${WAYLAND_DISPLAY}" || echo "  - WAYLAND: (not set)"
    [[ -n "${DBUS_SESSION_BUS_ADDRESS}" ]] && echo "  - D-Bus: available" || echo "  - D-Bus: (not set)"
    echo "  - sudo: $(command -v sudo &>/dev/null && echo 'available' || echo 'not found')"
    echo "  - pkexec: $(command -v pkexec &>/dev/null && echo 'available' || echo 'not found')"
    echo "  - su: $(command -v su &>/dev/null && echo 'available' || echo 'not found')"
    echo ""
    
    # Only warn in non-interactive mode, otherwise let user decide
    if [[ "$1" == "install" ]] && [[ "$ask" == "false" ]]; then
      tui_warn "Running in non-interactive mode - may fail. Consider:"
      echo "  1. Running interactively: ./setup install"
      echo "  2. Configure sudo first: sudo visudo"
      echo "  3. Or use a graphical terminal with polkit agent"
      echo ""
    fi
  fi
}

sync_launcher_from_repo() {
    local launcher_target="${XDG_BIN_HOME}/inir"
    if [[ -f "${REPO_ROOT}/scripts/inir" ]]; then
        mkdir -p "$XDG_BIN_HOME"
        cp -f "${REPO_ROOT}/scripts/inir" "$launcher_target"
        chmod +x "$launcher_target"
        ensure_launcher_path_in_shells "$XDG_BIN_HOME"
        printf '%s\n' "$launcher_target"
    fi
}

sync_user_inir_service_from_repo_if_present() {
    local service_asset="${REPO_ROOT}/assets/systemd/inir.service"
    local service_target_dir="${XDG_CONFIG_HOME}/systemd/user"
    local service_target="${service_target_dir}/inir.service"
    local launcher_target="${XDG_BIN_HOME}/inir"
    local tmp_file
    local changed=false

    [[ -f "$service_asset" ]] || return 1
    [[ -f "$service_target" ]] || return 1

    mkdir -p "$service_target_dir"
    mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}"
    tmp_file="${XDG_CACHE_HOME:-$HOME/.cache}/inir.service.$$"

    sed "s|^ExecStart=.*|ExecStart=${launcher_target//&/\\&} run --session|" "$service_asset" > "$tmp_file"

    if ! cmp -s "$tmp_file" "$service_target"; then
        changed=true
        cp -f "$tmp_file" "$service_target"
    fi

    rm -f "$tmp_file"

    if [[ "$changed" == true ]] && command -v systemctl >/dev/null 2>&1; then
        systemctl --user daemon-reload >/dev/null 2>&1 || true
    fi

    if [[ "$changed" == true ]]; then
        return 0
    fi

    return 1
}

ensure_user_inir_service_enabled() {
    if ! command -v systemctl >/dev/null 2>&1; then
        return 1
    fi

    local service_path="${XDG_CONFIG_HOME}/systemd/user/inir.service"
    if [[ ! -f "$service_path" ]]; then
        return 1
    fi

    systemctl --user daemon-reload >/dev/null 2>&1 || true
    systemctl --user enable inir.service >/dev/null 2>&1 || true
    return 0
}

###############################################################################
# Help
###############################################################################
show_help() {
    echo ""
    tui_title "iNiR setup"

    tui_key_value "Usage:" "./setup [command] [options]"
    echo ""

    tui_subtitle "Role"
    tui_dim "  setup owns installation and maintenance flows."
    tui_dim "  The \`inir\` launcher forwards install/update/doctor/status/migrate/rollback/my-changes/uninstall back to this script."
    tui_dim "  Use \`inir\` for daily runtime control, and \`./setup\` when you want the underlying maintenance entrypoint or the interactive TUI."
    echo ""

    tui_subtitle "Commands"
    tui_list_item "(none)      Interactive menu"
    tui_list_item "install     Full installation (deps + config + files)"
    tui_list_item "update      Check remote, pull, sync, restart shell"
    tui_list_item "status      Show install mode, update strategy, and health"
    tui_list_item "migrate     Review/apply config migrations"
    tui_list_item "doctor      Diagnose and fix problems"
    tui_list_item "rollback    Restore previous snapshot"
    tui_list_item "my-changes  View/restore your preserved modifications"
    tui_list_item "uninstall   Remove iNiR from system"
    tui_list_item "config      View and edit shell settings"
    tui_list_item "theme       Change wallpaper and color scheme"
    tui_list_item "info        System and shell details dashboard"
    tui_list_item "backup      Create a manual snapshot"
    tui_list_item "logs        View recent runtime logs"
    tui_list_item "extras      Install optional extras (iNiR-Walls / SDDM theme)"
    echo ""

    tui_subtitle "Options"
    tui_list_item "-y, --yes              Skip prompts (auto-yes)"
    tui_list_item "-q, --quiet            Minimal output"
    tui_list_item "--local                Sync local repo to install (skip git pull)"
    tui_list_item "--set-default-shell    Set Fish as default shell (uses chsh)"
    tui_list_item "-h, --help             Show this help"
    echo ""

    tui_subtitle "Examples"
    tui_dim "  ./setup install      # Install iNiR once"
    tui_dim "  ./setup theme        # Change wallpaper & colors"
    tui_dim "  ./setup config       # View/edit shell settings"
    tui_dim "  ./setup info         # Rich system dashboard"
    tui_dim "  ./setup backup       # Create a manual snapshot"
    tui_dim "  ./setup logs         # Browse runtime logs"
    tui_dim "  ./setup extras       # Optional extras installer"
    tui_dim "  inir update          # Wrapper around ./setup update"
    tui_dim "  inir doctor          # Wrapper around ./setup doctor"
    tui_dim "  inir run             # Start iNiR"
    tui_dim "  ./setup              # Advanced interactive menu"
    echo ""
}

###############################################################################
# Version Status Display
###############################################################################
show_version_info() {
    local installed_ver=$(get_installed_version)
    local installed_commit=$(get_installed_commit)
    local installed_mode=$(get_installed_install_mode)
    local update_strategy=$(get_installed_update_strategy)
    local installed_repo_path=$(get_installed_repo_path)
    local repo_ver
    local repo_commit
    local runtime_dir
    runtime_dir="$(get_runtime_shell_dir)"
    local runtime_dir_display="${runtime_dir:-"(missing)"}"

    if [[ -n "$installed_repo_path" && -f "${installed_repo_path}/VERSION" ]]; then
        repo_ver="$(head -1 "${installed_repo_path}/VERSION" | tr -d '[:space:]')"
        repo_commit="$(git -C "$installed_repo_path" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
    else
        repo_ver=$(get_repo_version)
        repo_commit=$(get_repo_commit)
    fi

    # Badge row for quick glance
    echo ""
    local badges_args=("Version" "$installed_ver" "accent")
    badges_args+=("Mode" "$installed_mode" "info")
    badges_args+=("Updates" "$update_strategy" "muted")
    tui_badge_row "${badges_args[@]}"

    echo ""
    tui_status_line "Installed:" "$installed_ver ($installed_commit)" "ok"
    tui_status_line "Runtime:" "$runtime_dir_display" ""

    if [[ "$update_strategy" == "package-manager" ]]; then
        local update_hint
        update_hint=$(get_installed_package_update_hint)
        [[ -n "$update_hint" ]] && tui_status_line "Command:" "$update_hint" ""
    elif [[ "$installed_mode" != "repo-link" ]]; then
        # For repo-copy: show what the local repo has vs what's deployed
        tui_status_line "Available:" "$repo_ver ($repo_commit)" ""
    fi

    # Check for pending migrations
    local pending=$(count_pending_migrations 2>/dev/null || echo "0")
    if [[ "$pending" -gt 0 ]]; then
        tui_status_line "Migrations:" "$pending pending" "warn"
    fi

    # Shell running status
    if [[ -n "$runtime_dir" && -f "$runtime_dir/shell.qml" ]]; then
        local running_output
        running_output="$(qs -p "$runtime_dir" list 2>/dev/null || true)"
        if [[ -n "$running_output" && "$running_output" != No\ running\ instances* ]]; then
            tui_status_line "Shell:" "running" "ok"
        else
            tui_status_line "Shell:" "stopped" "warn"
        fi
    fi

    # Check for updates
    if [[ "$update_strategy" != "package-manager" && "$installed_commit" != "$repo_commit" ]]; then
        echo ""
        tui_alert "info" "Update available" "Run './setup update' or 'inir update' to apply."
    fi
}

###############################################################################
# TUI Menu
###############################################################################
tui_menu() {
    clear
    tui_banner

    # Detect current state
    local is_installed=false
    [[ -f "${FIRSTRUN_FILE}" ]] && is_installed=true

    if $is_installed; then
        show_version_info
        echo ""
        tui_divider
    fi

    echo ""

    # Menu options based on state with rich descriptions
    local choice
    if $is_installed; then
        choice=$(tui_choose_rich "What would you like to do?" \
            "${ICON_ARROW}|Update|Check for updates and apply them" \
            "${ICON_CHECK}|Doctor|Diagnose and fix problems" \
            "${ICON_DOT}|Config|View and edit shell settings" \
            "${ICON_STAR}|Theme|Change wallpaper and color scheme" \
            "${ICON_DOT}|Extras|Install optional extras (iNiR-Walls / SDDM)" \
            "${ICON_INFO}|Info|System and shell details dashboard" \
            "${ICON_DOT}|Logs|View recent runtime logs" \
            "${ICON_DOT}|Migrate|Review and apply config migrations" \
            "${ICON_DOT}|Backup|Create a manual snapshot" \
            "${ICON_DOT}|Rollback|Restore a previous snapshot" \
            "${ICON_DOT}|My Changes|View your preserved modifications" \
            "${ICON_DOT}|Reinstall|Full reinstall from scratch" \
            "${ICON_CROSS}|Uninstall|Remove iNiR from the system" \
            "${ICON_CIRCLE}|Help|Show commands and usage" \
            "${ICON_CIRCLE}|Exit|")
    else
        choice=$(tui_choose_rich "What would you like to do?" \
            "${ICON_STAR}|Install|Full installation with dependencies" \
            "${ICON_CIRCLE}|Help|Show commands and usage" \
            "${ICON_CIRCLE}|Exit|")
    fi

    case "$choice" in
        Install) run_install ;;
        Reinstall) IS_UPDATE=true run_install ;;
        Update) run_update ;;
        Theme) run_theme ;;
        Extras) run_extras ;;
        Config) run_config ;;
        Info) show_info; read -rp "Press Enter to continue..." ;;
        Migrate) run_migrate ;;
        Doctor) run_doctor ;;
        Backup) run_backup ;;
        Rollback) run_rollback ;;
        "My Changes") run_my_changes ;;
        Logs) run_logs ;;
        Uninstall) run_uninstall ;;
        Help) show_help; read -rp "Press Enter to continue..." ;;
        Exit|"") return 1 ;;
        *) return 1 ;;
    esac

    return 0
}

###############################################################################
# Status Command
###############################################################################
show_status() {
    local installed_ver=$(get_installed_version)
    local installed_commit=$(get_installed_commit)
    local installed_mode=$(get_installed_install_mode)
    local update_strategy=$(get_installed_update_strategy)
    local installed_repo_path=$(get_installed_repo_path)
    local update_hint=$(get_installed_package_update_hint)
    local installed_version_file=$(get_installed_version_file)
    local repo_ver
    local repo_commit
    local runtime_dir=$(get_runtime_shell_dir)
    local runtime_version_file=""
    local running_output
    local runtime_dir_display="${runtime_dir:-"(missing)"}"

    if [[ -n "$runtime_dir" ]]; then
        runtime_version_file="$(get_runtime_version_file)"
    fi

    if [[ -n "$installed_repo_path" && -f "${installed_repo_path}/VERSION" ]]; then
        repo_ver="$(head -1 "${installed_repo_path}/VERSION" | tr -d '[:space:]')"
        repo_commit="$(git -C "$installed_repo_path" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
    else
        repo_ver=$(get_repo_version)
        repo_commit=$(get_repo_commit)
    fi

    tui_title "Status"

    tui_table_header "Property" "Value" 14 36
    tui_table_row "Version" "$installed_ver" 14 36
    tui_table_row "Commit" "$installed_commit" 14 36
    tui_table_row "Install Mode" "$installed_mode" 14 36
    tui_table_row "Updates" "$update_strategy" 14 36
    tui_table_row "Runtime Path" "$runtime_dir_display" 14 36
    tui_table_row "Launcher" "inir run" 14 36
    [[ -n "$installed_repo_path" ]] && tui_table_row "Repo Path" "$installed_repo_path" 14 36
    if [[ "$update_strategy" == "package-manager" ]]; then
        [[ -n "$update_hint" ]] && tui_table_row "Update Cmd" "$update_hint" 14 36
        tui_table_row "Workspace Ver" "$repo_ver" 14 36
        tui_table_row "Workspace SHA" "$repo_commit" 14 36
    else
        tui_table_row "Repo Version" "$repo_ver" 14 36
        tui_table_row "Repo Commit" "$repo_commit" 14 36
    fi
    tui_table_footer 14 36

    if [[ "$update_strategy" == "package-manager" ]]; then
        echo ""
        tui_info "This installation is externally managed. './setup update' will not sync repo files into the runtime."
    fi

    tui_title "Health Checks"

    # Check shell status
    if [[ -n "$runtime_dir" && -f "$runtime_dir/shell.qml" ]]; then
        running_output="$(qs -p "$runtime_dir" list 2>/dev/null || true)"
        if [[ -n "$running_output" && "$running_output" != No\ running\ instances* ]]; then
            tui_check_ok "Shell is running"
        else
            tui_check_warn "Shell is not running"
        fi
    else
        tui_check_warn "Runtime payload missing"
    fi

    if command -v inir &>/dev/null || [[ -x "${REPO_ROOT}/scripts/inir" ]]; then
        tui_check_ok "Launcher available"
    else
        tui_check_warn "Launcher not available in PATH"
    fi

    if [[ -f "$runtime_version_file" ]]; then
        tui_check_ok "Runtime metadata present"
    elif [[ "$installed_mode" == "repo-link" && -n "$installed_version_file" ]] && version_file_has_core_metadata "$installed_version_file"; then
        tui_check_ok "Repo-link metadata present via config tracking"
    else
        tui_check_warn "Runtime metadata missing"
    fi

    # Check Niri
    if [[ -n "$NIRI_SOCKET" ]]; then
        tui_check_ok "Niri compositor detected"
    else
        tui_check_warn "Not running in Niri session"
    fi

    # Pending migrations
    local pending=$(count_pending_migrations 2>/dev/null || echo "0")
    if [[ "$pending" -gt 0 ]]; then
        tui_check_warn "$pending pending migration(s)"
        tui_info "Run './setup migrate' to review"
    else
        tui_check_ok "No pending migrations"
    fi

    # Snapshots
    local snapshot_count=$(list_snapshots 2>/dev/null | wc -l)
    if [[ "$snapshot_count" -gt 0 ]]; then
        tui_check_ok "$snapshot_count snapshot(s) available"
    else
        tui_check_skip "No snapshots"
    fi
    echo ""
}

###############################################################################
# Info — Rich system & shell details dashboard (Ink StatusMessage-inspired)
###############################################################################
show_info() {
    echo ""
    tui_title "iNiR System Information"
    echo ""

    # System detection
    local distro_name="Unknown"
    local distro_id="unknown"
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release
        distro_name="${PRETTY_NAME:-$NAME}"
        distro_id="${ID}"
    fi

    local current_shell
    current_shell=$(basename "${SHELL:-unknown}")
    local session_type="${XDG_SESSION_TYPE:-unknown}"

    local compositor="Not detected"
    if [[ -n "$NIRI_SOCKET" ]]; then
        compositor="Niri"
    elif [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
        compositor="Hyprland"
    elif [[ -n "$SWAYSOCK" ]]; then
        compositor="Sway"
    elif [[ -n "$XDG_CURRENT_DESKTOP" ]]; then
        compositor="$XDG_CURRENT_DESKTOP"
    fi

    local kernel
    kernel=$(uname -r 2>/dev/null || echo "unknown")

    # iNiR details
    local installed_ver=$(get_installed_version)
    local installed_commit=$(get_installed_commit)
    local installed_mode=$(get_installed_install_mode)
    local runtime_dir
    runtime_dir="$(get_runtime_shell_dir)"
    local config_dir
    config_dir="$(resolve_inir_config_dir)"
    local config_file="${config_dir}/config.json"
    local state_dir="${XDG_STATE_HOME}/quickshell/user/generated"

    # Panel family detection
    local panel_family="unknown"
    if [[ -f "$config_file" ]]; then
        if command -v jq &>/dev/null; then
            panel_family=$(jq -r '.panelFamily // "ii"' "$config_file" 2>/dev/null || echo "ii")
        else
            panel_family=$(sed -n 's/.*"panelFamily"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$config_file" 2>/dev/null | head -1)
            [[ -z "$panel_family" ]] && panel_family="ii"
        fi
    fi

    # Current wallpaper
    local current_wallpaper="none"
    local theme_meta="${state_dir}/theme-meta.json"
    if [[ -f "$theme_meta" ]]; then
        if command -v jq &>/dev/null; then
            current_wallpaper=$(jq -r '.wallpaper // .source_path // "none"' "$theme_meta" 2>/dev/null || echo "none")
        else
            current_wallpaper=$(sed -n 's/.*"wallpaper"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$theme_meta" 2>/dev/null | head -1)
            [[ -n "$current_wallpaper" ]] || current_wallpaper=$(sed -n 's/.*"source_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$theme_meta" 2>/dev/null | head -1)
        fi
        [[ -n "$current_wallpaper" && "$current_wallpaper" != "null" ]] && current_wallpaper="$(basename "$current_wallpaper")"
    fi

    # Display using summary cards and columns
    local sys_info
    sys_info=$(printf '%s\n%s\n%s\n%s\n%s' \
        "Distro:      $distro_name" \
        "Kernel:      $kernel" \
        "Session:     $session_type" \
        "Compositor:  $compositor" \
        "Shell:       $current_shell")

    local shell_info
    shell_info=$(printf '%s\n%s\n%s\n%s\n%s\n%s' \
        "Version:     $installed_ver ($installed_commit)" \
        "Mode:        $installed_mode" \
        "Family:      $panel_family" \
        "Wallpaper:   $current_wallpaper" \
        "Config:      $config_dir" \
        "Runtime:     ${runtime_dir:-"(missing)"}")

    tui_columns "$sys_info" "$shell_info" 2

    echo ""

    # Paths
    tui_subtitle "Paths"
    tui_key_value "Config:" "$config_file"
    tui_key_value "State:" "$state_dir"
    tui_key_value "Runtime:" "${runtime_dir:-"(not set)"}"
    tui_key_value "Repo:" "$REPO_ROOT"
    tui_key_value "Launcher:" "$(command -v inir 2>/dev/null || echo "${XDG_BIN_HOME}/inir")"

    echo ""

    # Quick health
    tui_subtitle "Quick Health"
    if [[ -n "$runtime_dir" && -f "$runtime_dir/shell.qml" ]]; then
        local running_output
        running_output="$(qs -p "$runtime_dir" list 2>/dev/null || true)"
        if [[ -n "$running_output" && "$running_output" != No\ running\ instances* ]]; then
            tui_check_ok "Shell is running"
        else
            tui_check_warn "Shell is not running"
        fi
    else
        tui_check_warn "Runtime payload missing"
    fi

    local pending=$(count_pending_migrations 2>/dev/null || echo "0")
    if [[ "$pending" -gt 0 ]]; then
        tui_check_warn "$pending pending migration(s)"
    else
        tui_check_ok "No pending migrations"
    fi

    local snapshot_count=$(list_snapshots 2>/dev/null | wc -l)
    tui_check_ok "$snapshot_count snapshot(s) available"

    echo ""
}

###############################################################################
# Config — View and edit shell settings (Ink Select-inspired interactive)
###############################################################################
run_config() {
    echo ""
    tui_title "iNiR Configuration"
    echo ""

    local config_dir
    config_dir="$(resolve_inir_config_dir)"
    local config_file="${config_dir}/config.json"

    if [[ ! -f "$config_file" ]]; then
        tui_warn "Config file not found: $config_file"
        tui_info "Run './setup install' first."
        echo ""
        read -rp "Press Enter to continue..."
        return 0
    fi

    # Show current key settings
    local panel_family="ii"
    local bar_position="top"
    local clock_format="12h"
    local search_engine="google"
    local animations="true"
    local blur="true"

    if command -v jq &>/dev/null; then
        panel_family=$(jq -r '.panelFamily // "ii"' "$config_file" 2>/dev/null)
        bar_position=$(jq -r '.bar?.position // "top"' "$config_file" 2>/dev/null)
        clock_format=$(jq -r '.time?.format // "12h"' "$config_file" 2>/dev/null)
        search_engine=$(jq -r '.search?.engine // "google"' "$config_file" 2>/dev/null)
        animations=$(jq -r '.animations?.enabled // true' "$config_file" 2>/dev/null)
        blur=$(jq -r '.appearance?.blur // true' "$config_file" 2>/dev/null)
    fi

    tui_summary_card "Current Settings" \
        "Panel Family:$panel_family" \
        "Bar Position:$bar_position" \
        "Clock Format:$clock_format" \
        "Search Engine:$search_engine" \
        "Animations:$animations" \
        "Blur:$blur"

    echo ""

    local action
    action=$(tui_choose_rich "Configuration" \
        "${ICON_ARROW}|Edit in Editor|Open config.json in your editor" \
        "${ICON_DOT}|Panel Family|Switch between ii and waffle" \
        "${ICON_DOT}|Open Config Dir|Open the config directory" \
        "${ICON_DOT}|Reset to Defaults|Restore default configuration" \
        "${ICON_CIRCLE}|Back|Return to main menu")

    case "$action" in
        "Edit in Editor")
            local editor="${EDITOR:-${VISUAL:-nano}}"
            tui_info "Opening $config_file with $editor..."
            "$editor" "$config_file"
            tui_success "Config saved"
            tui_info "Run 'inir restart' to apply changes"
            ;;
        "Panel Family")
            echo ""
            local new_family
            new_family=$(tui_choose "Select panel family:" "ii" "waffle")
            if [[ -n "$new_family" && "$new_family" != "$panel_family" ]]; then
                if command -v jq &>/dev/null; then
                    local tmp_file
                    tmp_file=$(mktemp)
                    jq --arg f "$new_family" '.panelFamily = $f' "$config_file" > "$tmp_file" && mv "$tmp_file" "$config_file"
                    tui_success "Panel family set to: $new_family"
                    tui_info "Run 'inir restart' to apply"
                else
                    tui_warn "jq required to edit config programmatically"
                    tui_info "Edit $config_file manually"
                fi
            else
                tui_info "No change"
            fi
            ;;
        "Open Config Dir")
            if command -v xdg-open &>/dev/null; then
                xdg-open "$config_dir" &>/dev/null &
                tui_success "Opened in file manager"
            else
                tui_info "Path: $config_dir"
            fi
            ;;
        "Reset to Defaults")
            tui_warn "This will replace your config with defaults."
            if tui_confirm "Are you sure?" "no"; then
                if [[ -f "${REPO_ROOT}/defaults/config.json" ]]; then
                    cp "$config_file" "${config_file}.backup.$(date +%Y%m%d%H%M%S)"
                    cp "${REPO_ROOT}/defaults/config.json" "$config_file"
                    tui_success "Config reset to defaults (backup created)"
                    tui_info "Run 'inir restart' to apply"
                else
                    tui_error "Default config not found"
                fi
            fi
            ;;
        *)
            return 0
            ;;
    esac

    echo ""
    read -rp "Press Enter to continue..."
}

###############################################################################
# Theme — Quick wallpaper and color scheme operations
###############################################################################
run_theme() {
    echo ""
    tui_title "Theme & Wallpaper"
    echo ""

    local state_dir="${XDG_STATE_HOME}/quickshell/user/generated"
    local theme_meta="${state_dir}/theme-meta.json"
    local colors_file="${state_dir}/colors.json"
    local wallpaper_state_path="${state_dir}/wallpaper/path.txt"

    resolve_switchwall_script() {
        local candidate="${REPO_ROOT}/scripts/colors/switchwall.sh"
        if [[ -x "$candidate" ]]; then
            printf '%s' "$candidate"
            return 0
        fi

        if command -v inir &>/dev/null; then
            local runtime_dir
            runtime_dir="$(inir path 2>/dev/null || true)"
            candidate="${runtime_dir}/scripts/colors/switchwall.sh"
            if [[ -x "$candidate" ]]; then
                printf '%s' "$candidate"
                return 0
            fi
        fi

        return 1
    }

    # Show current theme info
    local current_wallpaper="none"
    local current_scheme="unknown"
    if [[ -f "$theme_meta" ]]; then
        if command -v jq &>/dev/null; then
            current_wallpaper=$(jq -r '.wallpaper // .source_path // "none"' "$theme_meta" 2>/dev/null)
            current_scheme=$(jq -r '.scheme // .variant // "unknown"' "$theme_meta" 2>/dev/null)
        else
            current_wallpaper=$(sed -n 's/.*"wallpaper"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$theme_meta" 2>/dev/null | head -1)
            [[ -n "$current_wallpaper" ]] || current_wallpaper=$(sed -n 's/.*"source_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$theme_meta" 2>/dev/null | head -1)
            current_scheme=$(sed -n 's/.*"scheme"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$theme_meta" 2>/dev/null | head -1)
            [[ -n "$current_scheme" ]] || current_scheme="unknown"
        fi
    fi

    local display_wallpaper="$current_wallpaper"
    [[ "$current_wallpaper" != "none" && -n "$current_wallpaper" && "$current_wallpaper" != "null" ]] && display_wallpaper="$(basename "$current_wallpaper")"

    tui_summary_card "Current Theme" \
        "Wallpaper:${display_wallpaper}" \
        "Scheme:${current_scheme}"

    echo ""

    local action
    action=$(tui_choose_rich "Theme Options" \
        "${ICON_STAR}|Browse Defaults|Pick from default wallpapers" \
        "${ICON_DOT}|Regenerate|Rebuild colors from current wallpaper" \
        "${ICON_CIRCLE}|Back|Return to main menu")

    case "$action" in
        "Regenerate")
            echo ""
            tui_info "Regenerating theme from current wallpaper..."
            local switchwall
            switchwall="$(resolve_switchwall_script || true)"
            local regen_wallpaper="$current_wallpaper"
            if [[ ( -z "$regen_wallpaper" || "$regen_wallpaper" == "none" || ! -f "$regen_wallpaper" ) && -f "$wallpaper_state_path" ]]; then
                regen_wallpaper="$(<"$wallpaper_state_path")"
            fi

            if [[ -n "$switchwall" && -n "$regen_wallpaper" && -f "$regen_wallpaper" ]]; then
                bash "$switchwall" "$regen_wallpaper" 2>/dev/null &
                disown
                tui_success "Color regeneration started"
            else
                tui_warn "Cannot regenerate — wallpaper path unknown or switchwall.sh missing"
            fi
            ;;
        "Browse Defaults")
            echo ""
            local defaults_dir="${REPO_ROOT}/defaults/wallpapers"
            if [[ ! -d "$defaults_dir" ]]; then
                # Try alternate paths
                for try_dir in \
                    "${REPO_ROOT}/assets/wallpapers" \
                    "${REPO_ROOT}/defaults/backgrounds" \
                    "${DOTS_CORE_CONFDIR}/wallpapers"; do
                    [[ -d "$try_dir" ]] && defaults_dir="$try_dir" && break
                done
            fi

            if [[ -d "$defaults_dir" ]]; then
                local wallpapers=()
                while IFS= read -r f; do
                    wallpapers+=("$(basename "$f")")
                done < <(find "$defaults_dir" -maxdepth 1 -type f \( -name "*.jpg" -o -name "*.jpeg" -o -name "*.png" -o -name "*.webp" \) | sort)

                if [[ ${#wallpapers[@]} -eq 0 ]]; then
                    tui_info "No wallpapers found in $defaults_dir"
                else
                    local chosen_wall
                    chosen_wall=$(printf '%s\n' "${wallpapers[@]}" | tui_filter "Search wallpapers...")
                    if [[ -n "$chosen_wall" ]]; then
                        local full_path="${defaults_dir}/${chosen_wall}"
                        tui_info "Applying: $chosen_wall"
                        local switchwall
                        switchwall="$(resolve_switchwall_script || true)"
                        if [[ -n "$switchwall" ]]; then
                            bash "$switchwall" "$full_path" 2>/dev/null &
                            disown
                            tui_success "Wallpaper pipeline started"
                        else
                            tui_error "switchwall.sh not found or not executable"
                        fi
                    fi
                fi
            else
                tui_info "No default wallpapers directory found"
            fi
            ;;
        *)
            return 0
            ;;
    esac

    echo ""
    read -rp "Press Enter to continue..."
}

