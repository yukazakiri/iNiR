    fi

    # 3. Config files
    if [[ "${SKIP_ALLFILES}" != "true" ]]; then
        tui_step 3 3 "Installing config files" "User configs, backups, wallpaper defaults, and generated theme inputs."
        source ./sdata/subcmd-install/3.files.sh
    fi

