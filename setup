###############################################################################
# Backup — Create a manual snapshot
###############################################################################
run_backup() {
    echo ""
    tui_title "Manual Backup"
    echo ""

    # Show existing snapshots
    local snapshot_count=$(list_snapshots 2>/dev/null | wc -l)
    tui_info "$snapshot_count existing snapshot(s)"
    echo ""

    if tui_confirm "Create a new snapshot of the current state?"; then
        echo ""
        tui_info "Creating snapshot..."

        local current_ver=$(get_installed_version)
        local current_commit=$(get_installed_commit)
        local snapshot_id
        snapshot_id=$(create_snapshot "manual" "Manual backup via setup TUI" "$current_commit")

        if [[ -n "$snapshot_id" ]]; then
            tui_alert "success" "Snapshot created" "ID: $snapshot_id\nVersion: $current_ver ($current_commit)\nRestore with: ./setup rollback"
        else
            tui_error "Failed to create snapshot"
        fi
    else
        tui_info "Cancelled"
    fi

    echo ""
    read -rp "Press Enter to continue..."
}

###############################################################################
# Logs — View recent runtime logs via pager
###############################################################################
run_logs() {
    echo ""
    tui_title "Runtime Logs"
    echo ""

    local log_sources=()
    local log_labels=()

    # Quickshell logs
    local qs_log="${XDG_STATE_HOME}/quickshell/log"
    local qs_log_alt="${XDG_CACHE_HOME}/quickshell/log"
    local journal_available=false
    command -v journalctl &>/dev/null && journal_available=true

    [[ -f "$qs_log" ]] && log_sources+=("$qs_log") && log_labels+=("Quickshell log (state)")
    [[ -f "$qs_log_alt" ]] && log_sources+=("$qs_log_alt") && log_labels+=("Quickshell log (cache)")

    if $journal_available; then
        log_sources+=("__journal_qs__")
        log_labels+=("Journal: quickshell (last 200 lines)")
        log_sources+=("__journal_niri__")
        log_labels+=("Journal: niri (last 100 lines)")
    fi

    if [[ ${#log_sources[@]} -eq 0 ]]; then
        tui_warn "No log sources found"
        tui_info "Start iNiR first: inir run"
        echo ""
        read -rp "Press Enter to continue..."
        return 0
    fi

    log_labels+=("Back")
    local choice
    choice=$(tui_choose "Select log source:" "${log_labels[@]}")

    [[ "$choice" == "Back" ]] && return 0

    # Find matching source
    local source_idx=0
    for i in "${!log_labels[@]}"; do
        if [[ "${log_labels[$i]}" == "$choice" ]]; then
            source_idx=$i
            break
        fi
    done

    local source="${log_sources[$source_idx]}"

    echo ""
    case "$source" in
        __journal_qs__)
            tui_info "Showing last 200 lines from journalctl..."
            if $HAS_GUM; then
                journalctl --user -u quickshell --no-pager -n 200 2>/dev/null | gum pager
            else
                journalctl --user -u quickshell --no-pager -n 200 2>/dev/null | less
            fi
            ;;
        __journal_niri__)
            tui_info "Showing last 100 lines from niri journal..."
            if $HAS_GUM; then
                journalctl --user -u niri --no-pager -n 100 2>/dev/null | gum pager
            else
                journalctl --user -u niri --no-pager -n 100 2>/dev/null | less
            fi
            ;;
        *)
            tui_info "Viewing: $source"
            if $HAS_GUM; then
                gum pager < "$source"
            else
                less "$source"
            fi
            ;;
    esac
}

###############################################################################
# Install
###############################################################################
run_install() {
    detect_distro

    # Greeting & system info
    source ./sdata/subcmd-install/0.greeting.sh

    # Check conflicts
    check_conflicts

    # Show tasuku-style task overview before starting
    echo ""
    tui_subtitle "Installation progress"
    echo ""
    tui_task_init \
        "Install dependencies" \
        "System configuration" \
        "Install config files" \
        "Version tracking"

    # 1. Dependencies
    if [[ "${SKIP_ALLDEPS}" != "true" ]]; then
        tui_task_run 0 "packages, runtime, compositor"
        tui_task_finalize
        tui_step 1 3 "Installing dependencies" "Package managers, shell runtime pieces, and compositor requirements."
        source ./sdata/subcmd-install/1.deps-router.sh
        # Reinit after step output to show updated state
        echo ""
        tui_task_init \
            "Install dependencies" \
            "System configuration" \
            "Install config files" \
            "Version tracking"
        _TUI_TASK_STATES[0]="done"
        _TUI_TASK_DETAILS[0]="complete"
        tui_task_render
