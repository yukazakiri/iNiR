// ─────────────────────────────────────────────────────────────────────────────
// 40 — Environment variables
// ─────────────────────────────────────────────────────────────────────────────
// These are set for every process spawned by Niri (including spawn-at-startup
// and keybind commands). They are NOT inherited by TTY/SSH sessions — for
// those, iNiR's setup writes equivalent exports into ~/.bashrc / fish conf.d.
// ─────────────────────────────────────────────────────────────────────────────

environment {
    // Tell apps which compositor is running (used by xdg-desktop-portal, etc.).
    XDG_CURRENT_DESKTOP "niri"

    // Use Plasma's app-menu prefix so kbuildsycoca6 indexes .desktop files
    // and Dolphin/Nautilus "Open With" menus work correctly.
    XDG_MENU_PREFIX "plasma-"

    // Force Qt apps to use Wayland natively (no XWayland fallback).
    QT_QPA_PLATFORM "wayland"

    // Let Electron apps (Chrome, VS Code, Discord) pick Wayland automatically.
    ELECTRON_OZONE_PLATFORM_HINT "auto"

    // Silence noisy Quickshell D-Bus property logs.
    QT_LOGGING_RULES "quickshell.dbus.properties=false"

    // Qt theming: "kde" reads colors from kdeglobals (requires plasma-integration).
    // If plasma-integration is not installed, iNiR's setup patches this to "qt6ct".
    QT_QPA_PLATFORMTHEME "kde"

    // Darkly is a modern Qt style that follows kdeglobals color schemes.
    QT_STYLE_OVERRIDE "Darkly"

    // Python venv used by iNiR scripts (matugen, AI features, translations).
    ILLOGICAL_IMPULSE_VIRTUAL_ENV "$HOME/.local/state/quickshell/.venv"
}
